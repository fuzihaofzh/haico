{
  "name": "haico",
  "version": "1.5.3",
  "description": "Human-Agent Interactive Collaboration Orchestrator (HAICO)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fuzihaofzh/haico.git"
  },
  "homepage": "https://haico.dev",
  "license": "MIT",
  "files": [
    "bin/",
    "dist/",
    "!dist/electron",
    "public/",
    "README.md"
  ],
  "bin": {
    "haico": "bin/haico.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:electron": "bash desktop/build-electron.sh",
    "start": "node dist/index.js",
    "dev": "nodemon --legacy-watch --signal SIGTERM --watch src --watch public --watch package.json --ext ts,js,json,html,css --exec \"node --import tsx src/index.ts\"",
    "dev:admin": "HAICO_DEFAULT_ADMIN=true nodemon --legacy-watch --signal SIGTERM --watch src --watch public --watch package.json --ext ts,js,json,html,css --exec \"node --import tsx src/index.ts\"",
    "test": "npm run build && npm run test:api && npm run test:unit",
    "test:unit": "node --import tsx --test --test-concurrency=1 test/unit/*.test.ts",
    "test:api": "npm run test:api:suite && npm run test:api:standalone",
    "test:api:suite": "npx tsx test/api.test.ts",
    "test:api:standalone": "node --import tsx --test --test-concurrency=1 test/api/*.test.ts",
    "test:api:grep": "node --import tsx --test --test-concurrency=1 --test-name-pattern",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');[['docx-preview/dist/docx-preview.min.js','vendor/docx-preview.min.js'],['xlsx/dist/xlsx.full.min.js','vendor/xlsx.full.min.js'],['jszip/dist/jszip.min.js','vendor/jszip.min.js'],['@vscode/codicons/dist/codicon.css','css/codicon.css'],['@vscode/codicons/dist/codicon.ttf','css/codicon.ttf']].forEach(([s,d])=>{try{fs.copyFileSync(p.join('node_modules',s),p.join('public',d))}catch(e){}})\""
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.1",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@vscode/codicons": "^0.0.45",
    "better-sqlite3": "^11.7.0",
    "docx-preview": "^0.3.7",
    "fastify": "^5.2.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.5",
    "node-cron": "^3.0.3",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
