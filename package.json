{
  "name": "agentopia",
  "version": "1.2.0",
  "description": "Multi-Agent Collaboration Platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/fuzihaofzh/agentopia.git"
  },
  "homepage": "https://github.com/fuzihaofzh/agentopia",
  "license": "MIT",
  "bin": {
    "agentopia": "bin/agentopia.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --exclude '*.db' --exclude '*.db-*' --exclude 'test/**' src/index.ts",
    "test": "npm run build && npx tsx test/api.test.ts",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');[['mammoth/mammoth.browser.min.js','mammoth.browser.min.js'],['xlsx/dist/xlsx.full.min.js','xlsx.full.min.js'],['jszip/dist/jszip.min.js','jszip.min.js']].forEach(([s,d])=>{try{fs.copyFileSync(p.join('node_modules',s),p.join('public','js',d))}catch(e){}})\""
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.1",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "node-cron": "^3.0.3",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
